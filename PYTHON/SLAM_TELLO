import os

# Must be set before any cv2.VideoCapture is opened. By default, FFmpeg
# queues incoming frames faster than a single-threaded loop can process
# them, so the displayed video drifts further and further behind live -
# these flags tell it to drop stale frames instead of buffering them.
os.environ["OPENCV_FFMPEG_CAPTURE_OPTIONS"] = (
    "fflags;nobuffer|flags;low_delay|framedrop;1|reorder_queue_size;0|max_delay;0"
)

import cv2
import numpy as np
import matplotlib

matplotlib.use("TkAgg")
import matplotlib.pyplot as plt

import logging
import time
from collections import deque
from tkinter import TclError
import socket
import threading

logging.basicConfig(
    filename="tello_slam_log.txt",
    level=logging.INFO,
    format="%(asctime)s %(levelname)s %(message)s",
)
TELLO_IP = "192.168.10.1"
TELLO_CMD_PORT = 8889
TELLO_VIDEO = "udp://0.0.0.0:11111"

LOCAL_PORT = 8889  # Must match TELLO_CMD_PORT: the Tello's firmware sends
                    # its "ok"/response packets back to UDP port 8889
                    # specifically, not to whatever source port the command
                    # actually came from. Binding anywhere else (e.g. 9000)
                    # means "command" gets sent fine but the reply is never
                    # received, causing repeated "No response" timeouts.
                    # This matches what djitellopy does internally.

sock: socket.socket | None = None
_sock_lock = threading.Lock()

_keepalive_stop = threading.Event()
_keepalive_thread: threading.Thread | None = None

def _keepalive_loop():

    while not _keepalive_stop.wait(8):
        try:
            send_command("command", timeout=3)
        except Exception as e:
            logging.exception(e)

def start_keepalive():
    global _keepalive_thread

    _keepalive_stop.clear()

    thread = threading.Thread(target=_keepalive_loop, daemon=True)

    thread.start()

    _keepalive_thread = thread

def stop_keepalive():

    _keepalive_stop.set()

    if _keepalive_thread is not None:
        _keepalive_thread.join(timeout=2)

def connect_tello(retries=3):
    global sock

    print("Connecting to TELLO...")

    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    s.bind(("", LOCAL_PORT))

    sock = s

    # The Tello frequently drops the very first UDP command it receives
    # after Wi-Fi association, so a single timeout here doesn't
    # necessarily mean anything is actually wrong - retry a few times
    # before giving up.
    response = None
    for attempt in range(1, retries + 1):
        response = send_command("command")
        if response is not None and response.lower() == "ok":
            break
        logging.warning("Attempt %d/%d to enter SDK mode failed (got %r)",
                         attempt, retries, response)

    if response is None or response.lower() != "ok":
        sock.close()
        sock = None
        raise RuntimeError(
            f"TELLO did not enter SDK command mode (got {response!r}) "
            f"after {retries} attempts. Make sure you are connected to "
            "the TELLO's WiFi network."
        )

    battery = send_command("battery?")
    if battery is not None:
        print(f"Battery: {battery}%")
    else:
        print("Battery: unknown (no response)")

    return True


def disconnect_tello():
    """Release the UDP socket used to talk to the TELLO."""
    global sock
    if sock is not None:
        sock.close()
        sock = None

def send_command(command, timeout=5):
    if sock is None:
        raise RuntimeError("TELLO is not connected.")

    with _sock_lock:

        sock.sendto(command.encode("utf-8"), (TELLO_IP, TELLO_CMD_PORT))
        sock.settimeout(timeout)

        try:
            response, _ = sock.recvfrom(1024)
            response = response.decode("utf-8").strip()

            logging.info("%s -> %s", command, response)

            return response

        except socket.timeout:
            logging.warning("Timeout waiting for response to '%s'", command)
            print(f"No response to '{command}'")
            return None

